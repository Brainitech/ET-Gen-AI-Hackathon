# ─────────────────────────────────────────────
# aether_ai — Environment Configuration
# ─────────────────────────────────────────────

# LLM: Local Ollama (default, no key needed)
# Make sure Ollama is running: `ollama run llama3.1:8b`
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# LLM: Groq Cloud (optional — faster, set key to enable)
# GROQ_API_KEY=your_groq_api_key_here

# App settings
APP_ENV=development
APP_PORT=8000
